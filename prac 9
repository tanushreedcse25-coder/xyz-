<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Simple Responsive Page</title>

<!-- Icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
body{
font-family:Arial;
margin:0;
}

header{
background:green;
color:white;
text-align:center;
padding:15px;
animation:move 1s;
}

@keyframes move{
from{opacity:0;}
to{opacity:1;}
}

.container{
column-count:3;
padding:10px;
}

.box{
background:#f4f4f4;
padding:10px;
margin:10px;
display:inline-block;
width:100%;
transition:0.3s;
}

.box:hover{
transform:scale(1.05);
}

footer{
background:black;
color:white;
text-align:center;
padding:10px;
}

@media(max-width:700px){
.container{
column-count:1;
}
}
</style>
</head>

<body>

<header>
<h2>Responsive Web Page</h2>
</header>

<div class="container">

<div class="box">
<i class="fa fa-star"></i>
<h3>Box 1</h3>
<p>This is simple column layout.</p>
</div>

<div class="box">
<i class="fa fa-heart"></i>
<h3>Box 2</h3>
<p>Icons are used here.</p>
</div>

<div class="box">
<i class="fa fa-user"></i>
<h3>Box 3</h3>
<p>Responsive using media query.</p>
</div>

</div>

<footer>
<p>Simple CSS3 Design</p>
</footer>

</body>
</html>